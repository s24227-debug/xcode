import SwiftUI

struct ContentView: View {
    //じゃんけんの結果を格納する変数 (0=初期画面、1=グー、2=チョキ、3=パー)
    @State var jankenNumber = 0
    
    var body: some View {
        //垂直にレイアウト(縦方向にレイアウト)
        VStack{
            
            
            //じゃんけんの数字が0だったら
            if jankenNumber == 0{
                //初期画面のテキスト表示
                Text("これからじゃんけんします！")
            } else if jankenNumber == 1 {
                //じゃんけんの数字が1だったら、グーの画像を指定
                //グー画像を指定
                Image(.gu)
                //リサイズを設定
                    .resizable()
                //画像に収まるように、アスペクト比(縦横比)を維持する設定
                    .scaledToFit()
                //じゃんけんの種類を設定
                Text("グー")
                
            } else if jankenNumber == 2{
                //じゃんけんの数字が2だったら、チョキの画像を指定
                //チョキ画像を指定
                Image(.gu)
                //リサイズを設定
                    .resizable()
                //画像に収まるように、アスペクト比(縦横比)を維持する設定
                    .scaledToFit()
                //じゃんけんの種類を設定
                Text("チョキ")
                
            } else {
                //じゃんけんの数字が「1」、「2」以外だったらパーの画像を指定
                //パー画像を指定
                Image(.gu)
                //リサイズを設定
                    .resizable()
                //画像に収まるように、アスペクト比(縦横比)を維持する設定
                    .scaledToFit()
                //じゃんけんの種類を設定
                Text("パー")
                
            }//ifここまで
            
            Button {
                //次のじゃんけん
                jankenNumber = jankenNumber + 1
                //Buttonでタップされたときの動きを記述
                print("タップされたよ！")
            } label: {
                //Buttanに表示する文字設定
                Text("じゃんけんをする!")
            }//「じゃんけんをする！」ボタンここまで

        }//VStackにここまで
    }//bodyここまで
}//ContentViewここまで

#Preview {
    ContentView()
}

